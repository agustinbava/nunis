{
  "expo": {
    "name": "Nunis",
    "slug": "nunis",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "nunis",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
